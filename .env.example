# JellyTunes Environment Variables
# Copy this to .env and fill in your values

# Jellyfin Server
SERVER_URL=http://localhost:8096
SERVER_NAME=jellyfin
SERVER_TYPE=jellyfin
SERVER_LOCK=true

# Metadata Enrichment (optional but recommended)
# Get a free Last.fm API key: https://www.last.fm/api/account/create
LASTFM_API_KEY=

# Get a free Fanart.tv API key: https://fanart.tv/get-an-api-key/
FANART_TV_API_KEY=

# MusicBrainz is always enabled (free, no key required)
MUSICBRAINZ_ENABLED=true
