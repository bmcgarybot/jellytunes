{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/env.d.ts",
    "src/renderer/**/*",
    "src/renderer/**/*.tsx",
    "src/preload/*.d.ts",
    "src/i18n/**/*",
    "src/main/features/core/lyrics/furigana.ts",
    "src/shared/**/*",
    "src/remote/**/*",
    "package.json"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "/@/renderer/*": [
        "src/renderer/*"
      ],
      "/@/lyrics-conversion-api": [
        "src/main/features/core/lyrics/furigana.ts"
      ],
      "/@/shared/*": [
        "src/shared/*"
      ],
      "/@/i18n/*": [
        "src/i18n/*"
      ],
      "/@/remote/*": [
        "src/remote/*"
      ]
    }
  },
}
